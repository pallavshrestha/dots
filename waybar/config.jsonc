{
    "spacing": 10,
    "height": 10,
    "margin": "6 4 0 4",
    "modules-left": ["custom/appdrawer","niri/workspaces","backlight","group/network"],
    "modules-center": ["mpris","clock","idle_inhibitor","wlr/taskbar"],
    "modules-right": ["group/hardware","battery","temperature","pulseaudio","tray","custom/powerbutton"],
    "layer": "top",
    "custom/appdrawer": {
        "format": "  у°Ђ»",
        "on-click": "appdrawer",
        "tooltip": false
    },
    "custom/powerbutton":{
        "format": "пЂ‘  ",
        "on-click": "powerapp",
        "tooltip": false
    },
    "group/network": {
    	"orientation": "inherit",
        "drawer": {
        "transition-duration": 500,
        "children-class": "",
        "transition-left-to-right": true
        },
    	"modules": [
            "network",
            "custom/network"
    	]
    },
    "group/hardware": {
		"orientation": "inherit",
        "drawer": {
        "transition-duration": 500,
        "children-class": "",
        "transition-left-to-right": false
        },
		"modules": [
            "cpu",
            "memory"
		]
	},
    "battery": {
        "states": {
            "good": 85,
            "decent": 60,
            "warning": 30,
            "critical": 15
        },
        // "format-good": "", // An empty format will hide the module
        "format":  "{icon}",
        "format-discharging": "{icon}",
        "format-charging": "<span color='#a3be8c'>п„‚ </span>{icon}",
        "tooltip-format": "{capacity}%",
        "format-plugged": "п‡¦",
        "format-full": "п‡¦ {icon}",
        "format-icons": {
           "default": ["у°‚Ћ","у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ","у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"] 
            }
    },
    "clock": {
        "format": " пЂ—  {:%H:%M}",
        "format-alt": " п—Ї  {:%A, %B %d, %Y (%R)}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode"          : "month",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "left",
            "on-scroll"     : 1,
            "format": {
                      "months":     "<span color='#8fbcbb'><b>{}</b></span>",
                      "days":       "<span color='#eceff4'><b>{}</b></span>",
                      "weeks":      "<span color='#8fbcbb'><b>W{:%U}</b></span>",
                      "weekdays":   "<span color='#d8dee9'><b>{}</b></span>",
                      "today":      "<span color='#ebcb8b'><b><u>{}</u></b></span>"
                      }
            },
            "actions":  {
                "on-click-right": "mode",
                "on-scroll-up": "tz_up",
                "on-scroll-down": "tz_down",
                "on-scroll-up": "shift_up",
                "on-scroll-down": "shift_down"
            }
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["оЏ” ", "оЏђ ", "оЏ‹ ", "оЏЈ "]
    },
    "cpu": {
         "interval": 1,
         "format": " о‰¦  {avg_frequency:0.2f} GHz"
    },
    "memory": {
        "interval": 30,
        "format": " пѓ‰ {used:0.1f}G/{total:0.1f}G"
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 20,
        "icon-theme": "Qogir-Dark",
        "tooltip-format": "{title} | {app_id}",
        "on-click": "activate",
        "on-click-right": "minimize",
        "active-first": true,
        "on-click-middle": "close",
        "ignore-list": [
            "Alacritty"
        ],
        "app_ids-mapping": {
            "zoom": "Zoom Workplace"
        },
        "rewrite": {
            "Firefox Web Browser": "Firefox",
            "Foot Server": "Terminal",
            "Alacritty": "Terminal",
            "Zoom Workplace - Licensed Account": "Zoom"
        }
    },
    "niri/workspaces": {
        "format": "{icon}",
        "format-icons": {
        	// Named workspaces
        	// (you need to configure them in niri)
        	// Icons by state
            "active": "п†’", //"о®Љ оЄ« п†’  п„Њ " 
        		"default": "п„Њ"
        },
        "tooltip-format": "{value} | {name} | {index} | {output}"
    },
    "idle_inhibitor": {
    	"format": "{icon}",
    	"format-icons": {
    		"activated": "п‡‘ ", //"пЃ® пЃ° "
    		"deactivated": "п‡ђ "
    	}
    },
    "keyboard-state": {
        "numlock": false,
        "capslock": true,
        "format": {
            "numlock": " N {icon}",
            "capslock": " C {icon}"
        },
        "format-icons": {
            "locked": "пЂЈ ",
            "unlocked": "о­ґ "
        }
    },
        "custom/network": {
            "exec": "$HOME/.config/waybar/scripts/wifi-status.sh",
            "interval": 5,
            "return-type": "json",
            "format": "{}",
            "tooltip": true
        },
        "network": {
            "interface": "wlp1s0",
            "format-wifi": "п‡«  {signalStrength}%",
            "format-ethernet": "пѓЃ  {ipaddr}/{cidr}",
            "format-disconnected": " у°–Є Disconnected",
            "tooltip-format-wifi": "п‡«   {essid}",
            "tooltip-format-ethernet": " пѓЃ  {ifname}",
            "tooltip-format-disconnected": "No connection",
            "interval": 5
        },
        "pulseaudio": {
            "format": "{icon}  {volume}%",
            "format-bluetooth": "{icon} пЉ” {volume}%",
            "format-muted": "пЂ¦ ",
            "format-icons": {
                "alsa_output.pci-0000_00_1f.3.analog-stereo": " оЊ­ ",
                "alsa_output.pci-0000_00_1f.3.analog-stereo-muted": " о»ЁоЊ­ ",
                "headphone": "пЂҐ ",
                "hands-free": "у±†Џ ",
                "headset": "о№™ ",
                "phone": "п‚• ",
                "phone-muted": "оґ— ",
                "portable": "у°¦ў ",
                "car": "п†№ ",
                "default": ["пЂ§ ", "пЂЁ "]
            },
            "scroll-step": 1,
            "on-click": "pavucontrol",
            "ignored-sinks": ["Easy Effects Sink"]
        },
       "tray": {
           "icon-size": 15,
           "spacing": 10,
           "icons": {
               "blueman": "bluetooth",  
               "teams-for-linux": "$HOME/applications/teams/icons/mono-light.png"
           }
        },
        //"mpd": {
        //    "format": "{stateIcon} {title}",
        //    "state-icons": {
        //        "playing": " пЃ‹ ",     // Icon for playing
        //        "paused": " пЃЊ ",      // Icon for paused
        //        "stopped": " пЃЌ "      // Icon for stopped
        //    },
        //    "tooltip-format": "пЃј  {album}\nпЂ‡  {artist}\nпЂЃ  {title}",
        //    "interval": 1,
        //    "on-click": "mpc toggle",         
        //    "on-scroll-up": "mpc next",     
        //    "on-scroll-down": "mpc prev"
        //},
    	"temperature": {
    		"thermal-zone": 1,
    		// "hwmon-path":
    		// "hwmon-path-abs":
    		// "input-filename":
    		"critical-threshold": 90,
    		"interval": 10,
    		"format-critical": "у°Ђ¦ {temperatureC}В°C",
    		"format": "{icon} {temperatureC}В°C",
    		"format-icons": [
    			"у±ѓѓ", "у°”Џ", "у±ѓ‚"
    		],
    		// "rotate":
    		"min-length": 8,
    		"max-length": 8
    		// "on-click":
    		// "on-click-middle":
    		// "on-click-right":
    		// "on-scroll-up":
    		// "on-scroll-down":
    		// "smooth-scrolling-threshold":
    		// "tooltip":
    		//"tooltip-format": "Temp in Fahrenheit: {temperatureF}В°F"
    	},
        "mpris": {
            "player":"playerctld",
        	"format": "{player_icon} {status_icon}{dynamic}",
        	"format-paused": "{player_icon} {status_icon} {dynamic}",
            "dynamic-order": ["title", "artist", "album"],
            "dynamic-len": 20,
            "dynamic-separator": "-",
        	"player-icons": {
        		"default": " рџЋµ",
        		"mpv": "рџЋµ"
        	},
        	"status-icons": {
        		"playing": "пЃЊ ",
                "paused": "пЃ‹ "
        	},
        	"ignored-players": ["firefox","chromium"]
        }
}
